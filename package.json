{
  "name": "scraper-oefa-tfa",
  "version": "0.1.0",
  "description": "Scraper en TypeScript para el Registro de Infracciones y Sanciones (OEFA / TFA). Navega los resultados paginados, extrae los datos de cada documento y descarga los PDFs asociados manejando rate limiting (429).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "scrape": "ts-node src/index.ts",
    "retry": "ts-node src/index.ts --retry-failed",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "scraper",
    "typescript",
    "oefa",
    "jsf",
    "primefaces"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "cheerio": "^1.2.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
